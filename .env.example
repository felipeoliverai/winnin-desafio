# Google AI Studio API key — https://aistudio.google.com
GEMINI_API_KEY=your_key_here

# Gemini model name (function calling supported)
# Default: gemini-2.5-flash (2.0-flash also works if your project has free-tier quota for it)
GEMINI_MODEL=gemini-2.5-flash

# Path where ChromaDB persists the vector store
CHROMA_PATH=./data/chroma

# Path where downloaded PDFs are stored
PDF_DIR=./data/pdfs

# Embedding model (default ChromaDB onnx — all-MiniLM-L6-v2)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Number of chunks returned by search_documents
TOP_K=4

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
